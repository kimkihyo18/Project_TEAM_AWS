{
  "family": "auth-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::956718674105:role/ThreeTier-ECS-TaskExecution-Role",
  "containerDefinitions": [
    {
      "name": "auth-service",
      "image": "956718674105.dkr.ecr.ap-northeast-2.amazonaws.com/auth-service:latest",
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "APP_MODE",        "value": "local"},
        {"name": "PORT",            "value": "3001"},
        {"name": "AWS_REGION",      "value": "ap-northeast-2"},
        {"name": "DB_HOST",         "value": "threetier-mysql.clu8oyeocrfy.ap-northeast-2.rds.amazonaws.com"},
        {"name": "DB_PORT",         "value": "3306"},
        {"name": "DB_USER",         "value": "admin"},
        {"name": "DB_PASSWORD",     "value": "Test-db-password1!"},
        {"name": "DB_NAME",         "value": "auth_db"},
        {"name": "JWT_SECRET",      "value": "test-jwt-secret-32chars-minimum1"},
        {"name": "INTERNAL_SECRET", "value": "test-internal-secret-value"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/auth-service",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3001/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3
      }
    }
  ]
}